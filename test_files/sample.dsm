// Sample DSM file for testing the parser
namespace TestNamespace {f2d9ea90-2adc-4e9a-a2bf-02288281747d} {

// Concepts with inheritance
concept User;
concept Admin is a User;
concept Guest is a User;

// Struct with fields and default values
"""User data structure."""
struct UserData {
    string username;
    string email;
    uint32 age = 0;
    bool isActive = true;
    optional<string> phoneNumber;
    vec<float, 3> position;
};

// Enum
"""User status enumeration."""
enum UserStatus {
    active,
    inactive,
    suspended,
    deleted
};

// Club and memberships
club Entity;
membership Entity User;
membership Entity Admin;

// Attachment
"""Attaches user data to User concept."""
attachment<User, UserData> data;
};

// Function pool
"""Utility functions."""
function_pool Utils {dc9740c9-9d1d-4c1e-9caa-4c8843b91e82} {
"""Returns a + b."""
int64 add(int64 a, int64 b);

"""Checks if value is even."""
bool isEven(int64 value);
};

// Attachment function pool
"""User management operations."""
attachment_function_pool UserManagement {9bdcbb5b-76e9-426f-b8a6-a10ed2d949e6} {
"""Creates a new user."""
mutable key<User> createUser(string username, string email);

"""Updates user email."""
mutable void updateEmail(key<User> userKey, string newEmail);

"""Gets all active users."""
set<key<User>> getActiveUsers();

"""Deletes a user."""
mutable void deleteUser(key<User> userKey);
};

